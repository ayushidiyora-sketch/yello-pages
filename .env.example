# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=yellowpages

# Optional paid US proxy gateway for yellowpages.com.
# The US site geo-blocks non-US IPs via Cloudflare, so a US exit IP is required.
# Format (rotating gateway): PROXY_URL=http://USERNAME:PASSWORD@us-gateway.host:PORT
# Leave empty to use the built-in rotating pool of free US proxies (flaky/slow).
PROXY_URL=

# Rotating paid-proxy pool. OPTIONAL — the app already defaults to reading `proxies.txt` in the project
# root, so you do NOT need to set this or even have a .env: just drop proxies.txt next to the app and
# rotation works (Walmart, Google core Search/News/Images/Videos, YouTube Transcripts, BestBuy, Trends).
# Set this only to override the path or pass an inline whitespace/comma list of proxies.
PROXY_LIST=

# Per-service dedicated proxies (each read ONLY by its own scraper; global PROXY_URL stays untouched).
# Format: http://USERNAME:PASSWORD@IP:PORT
# Walmart Products/Reviews — REQUIRED for Walmart to work (free pool is PerimeterX-blocked → 0 rows).
WALMART_PROXY_URL=
# BestBuy headless "all products" render — US proxy (free pool flaky / geo-blocked).
BESTBUY_PROXY_URL=
# Trustpilot — proxy-only (never the real IP). Needs a residential proxy for data (Cloudflare).
TRUSTPILOT_PROXY_URL=

# Email for Reviews Monitoring reports. Resend (https://resend.com) is the simplest — just an API
# key (RESEND_API_KEY), no SMTP host/port. RESEND_FROM must be a verified-domain sender;
# "onboarding@resend.dev" works unverified but only emails your own Resend account address.
# When RESEND_API_KEY is set it takes priority over SMTP_*.
RESEND_API_KEY=
RESEND_FROM=Live Scraper <onboarding@resend.dev>
# SMTP fallback (used only when RESEND_API_KEY is empty). For Gmail use an App Password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Scraper tuning
MAX_PAGES=50
MIN_DELAY=1.0
MAX_DELAY=3.0
REQUEST_TIMEOUT=30

# Google Maps Reviews Scraper renders Maps in a headless browser and scrolls all reviews. It needs
# the paid residential PROXY_URL above — Google blocks free/datacenter IPs. No API key required.
